{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "weaco-weather-api",
  "main": "worker/api.ts",
  "compatibility_date": "2026-07-18",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "keep_vars": true,
  "vars": {
    "ALLOWED_ORIGINS": "https://weaco.co.kr"
  },
  "triggers": {
    "crons": ["0 23 * * SUN-THU"]
  }
}
